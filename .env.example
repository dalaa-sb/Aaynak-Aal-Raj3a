# ─── MongoDB ───────────────────────────────────────────────
# Replace with YOUR connection string. Never commit real credentials.
MONGO_URL=mongodb+srv://<username>:<password>@<cluster-url>/?appName=<app-name>
MONGO_DB_NAME=aarvision

# ─── Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment marker (development | production)
ENVIRONMENT=development

# ─── JWT ───────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_secure_64_character_secret_generated_via_token_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── Password Reset ────────────────────────────────────────
RESET_TOKEN_EXPIRE_MINUTES=15

# ─── Email Verification ────────────────────────────────────
VERIFICATION_CODE_EXPIRE_MINUTES=15
# In production, integrate a real SMTP service. In dev, codes are printed to console.
DEV_PRINT_VERIFICATION_CODES=true

# ─── ID Upload ─────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# ─── Trusted hosts (HTTP Host header attack protection) ─────
# Comma-separated allowlist. In dev: localhost only.
# In production: set to your real backend domain(s), e.g.
# ALLOWED_HOSTS=aar-backend.onrender.com,localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,0.0.0.0

# ─── Internal API Authentication ───────────────────────────
# Shared secret between the AI module and the backend's /api/queue/ingest
# and /api/tracking/ingest endpoints. Prevents random clients from posting
# fake queue counts or tracking events to a publicly-hosted backend.
#
# When empty (dev mode), the check is disabled and any caller is accepted.
# In production, MUST be set to the same value on both:
#   - the backend (Render env var)
#   - the AI module's host (your laptop's .env)
#
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=

# ─── AI Module ─────────────────────────────────────────────
API_URL=http://localhost:8000
WEBCAM_SOURCE=0
